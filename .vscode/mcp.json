{
	"servers": {
		"angular-cli": {
			"command": "npx",
			"args": [
				"-y",
				"@angular/cli",
				"mcp"
			],
			"type": "stdio"
		},
		"sonarqube": {
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"-i",
				"-e",
				"SONARQUBE_TOKEN=${input:sonar_token}",
				"-e",
				"SONARQUBE_ORG=${input:sonar_org}",
				"mcp/sonarqube"
			],
			"type": "stdio"
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"Authorization": "Bearer ${input:github_token}"
			}
		},
		"supabase": {
			"type": "http",
			"url": "https://mcp.supabase.com/mcp?project_ref=xzfenjxeghaygstptvus&read_only=true&features=storage,branching,functions,development,debugging,database,account,docs"
		}
	},
	"inputs": [
		{
			"type": "promptString",
			"id": "github_token",
			"description": "GitHub Fine-grained Token",
			"password": true
		},
		{
			"type": "promptString",
			"id": "sonar_token",
			"description": "SonarQube Token",
			"password": true
		},
		{
			"type": "promptString",
			"id": "sonar_org",
			"description": "SonarQube Organization"
		}
	]
}