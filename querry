-- 1. Tabla Perfil (Vinculada a auth.users)
CREATE TABLE public.perfil (
    id UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
    nombre TEXT,
    apellido TEXT,
    rol TEXT NOT NULL DEFAULT 'viajero'
        CHECK (rol IN ('viajero', 'proveedor', 'admin')),
    fecha_registro TIMESTAMPTZ DEFAULT NOW(),
    estado TEXT NOT NULL DEFAULT 'activo'
        CHECK (estado IN ('activo', 'inactivo'))
);

-- 2. Tabla Perfil Viajero
CREATE TABLE public.perfil_viajero (
    id UUID PRIMARY KEY REFERENCES public.perfil(id) ON DELETE CASCADE,
    intereses TEXT,
    presupuesto DECIMAL(12, 2),
    idioma TEXT
);

-- 3. Tabla Destino
CREATE TABLE public.destino (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    nombre TEXT NOT NULL,
    ciudad TEXT,
    pais TEXT,
    descripcion TEXT,
    tipo_experiencia TEXT,
    imagen TEXT
);

-- 4. Tabla: establecimiento_turistico
CREATE TABLE establecimiento_turistico (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_proveedor UUID REFERENCES perfil(id) ON DELETE CASCADE,
    id_destino UUID REFERENCES destino(id) ON DELETE CASCADE,
    nombre TEXT NOT NULL,
    tipo TEXT,
    descripcion TEXT,
    estado TEXT DEFAULT 'activo' CHECK (estado IN ('activo', 'inactivo'))
);

-- 5. Tabla: servicio_reservable
CREATE TABLE servicio_reservable (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_establecimiento UUID REFERENCES establecimiento_turistico(id) ON DELETE CASCADE,
    nombre TEXT NOT NULL,
    precio NUMERIC(10, 2) NOT NULL,
    descripcion TEXT,
    comodidades_adicionales TEXT,
    disponibilidad BOOLEAN DEFAULT TRUE
);

-- 6. Tabla Itinerario
CREATE TABLE public.itinerario (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_perfil UUID NOT NULL REFERENCES public.perfil(id) ON DELETE CASCADE,
    nombre TEXT NOT NULL,
    fecha_inicio DATE,
    fecha_fin DATE,
    estado TEXT DEFAULT 'borrador'
);

-- 7. Tabla Detalle Itinerario
CREATE TABLE public.detalle_itinerario (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_itinerario UUID NOT NULL REFERENCES public.itinerario(id) ON DELETE CASCADE,
    id_servicio_reservable UUID NOT NULL REFERENCES public.servicio_reservable(id) ON DELETE CASCADE,
    fecha DATE,
    hora TIME,
    prioridad TEXT,
    estado TEXT
);

-- 8. Tabla Reserva
CREATE TABLE reserva (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_perfil UUID REFERENCES perfil(id) ON DELETE CASCADE,
    id_servicio_reservable UUID REFERENCES servicio_reservable(id) ON DELETE CASCADE,
    fecha_reserva DATE DEFAULT CURRENT_DATE,
    cantidad_personas INTEGER NOT NULL DEFAULT 1,
    precio_total NUMERIC(10, 2) NOT NULL,
    estado TEXT DEFAULT 'pendiente' CHECK (estado IN ('pendiente', 'aceptado', 'rechazado'))
);

-- 9. Tabla Recomendacion
CREATE TABLE public.recomendacion (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_perfil UUID NOT NULL REFERENCES public.perfil(id) ON DELETE CASCADE,
    id_establecimiento_turistico UUID NOT NULL REFERENCES public.establecimiento_turistico(id) ON DELETE CASCADE,
    motivo TEXT,
    fecha_generada TIMESTAMPTZ DEFAULT NOW()
);

-- 10. Tabla Notificacion
CREATE TABLE public.notificacion (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_perfil UUID NOT NULL REFERENCES public.perfil(id) ON DELETE CASCADE,
    mensaje TEXT NOT NULL,
    fecha_envio TIMESTAMPTZ DEFAULT NOW(),
    leida BOOLEAN DEFAULT FALSE
);

-- 11. Tabla: solicitud_proveedor
CREATE TABLE solicitud_proveedor (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_perfil UUID REFERENCES perfil(id) ON DELETE CASCADE,
    nombre_negocio TEXT NOT NULL,
    descripcion TEXT,
    telefono TEXT,
    documento_url TEXT,
    estado TEXT DEFAULT 'pendiente' CHECK (estado IN ('pendiente', 'aceptado', 'rechazado')),
    fecha_solicitud TIMESTAMPTZ DEFAULT NOW()
);